# ─────────────────────────────────────────────────────────────────────────────
# .dockerignore — exclude everything that shouldn't go into the build context
# Keeps the Docker build fast and the image small
# ─────────────────────────────────────────────────────────────────────────────

# Dependencies (reinstalled fresh by npm ci inside the container)
node_modules/
**/node_modules/

# Build output (rebuilt inside the container)
dist/
build/

# Version control
.git/
.gitignore
.gitattributes

# Docker files themselves (no need to copy into the image)
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (secrets must never go into the image)
.env
.env.*
!.env.example

# Test / CI files
*.test.*
*.spec.*
__tests__/
coverage/
.nyc_output/

# Docs (not needed at runtime)
README.md
CHANGELOG.md
docs/

# CI/CD
.gitlab-ci.yml
.github/
.circleci/
